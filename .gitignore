# ────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
/aether
dist/

# Go modules
vendor/

# ────────────────────────────────────────────────────────────────
# Rust Build Outputs
# ────────────────────────────────────────────────────────────────
runtime/target/
sdk/rust/target/

# ────────────────────────────────────────────────────────────────
# Test & Coverage Artifacts
# ────────────────────────────────────────────────────────────────
coverage
coverage.txt
coverage.out
coverage.html

# ────────────────────────────────────────────────────────────────
# Lint, Benchmark & Test Output Files
# ────────────────────────────────────────────────────────────────
lint_results.txt
lint.txt
bench_results.txt
test_output.txt

# ────────────────────────────────────────────────────────────────
# Log Files
# ────────────────────────────────────────────────────────────────
*.log
tmp.log

# ────────────────────────────────────────────────────────────────
# Editor and OS
# ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# ────────────────────────────────────────────────────────────────
# Env and Secrets
# ────────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key

# ────────────────────────────────────────────────────────────────
# Local Data
# ────────────────────────────────────────────────────────────────
data/
*.db
*.sqlite
~/.aether/
